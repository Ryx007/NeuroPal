# Backend host — the Mac Mini's LAN IP + port (see neuropal-backend/docs/MAC-MINI-SETUP.md §8).
# Find it on the Mini with: ipconfig getifaddr en1   (en1 = WiFi; en0 = Ethernet)
# Expo inlines EXPO_PUBLIC_* at bundle time — restart `expo start` after changing.
EXPO_PUBLIC_API_BASE_URL=http://192.168.3.169:4000

# Mock mode (explicit opt-in). true = UI runs on bundled fake data, no backend
# needed. Anything else = real backend only; connection failures are surfaced.
EXPO_PUBLIC_USE_MOCK=false
