# Backend host — preferred address first. The Tailscale MagicDNS name works
# on-LAN and off-LAN and survives DHCP drift (needs Tailscale ON on the
# device); find it on the Mini with:  tailscale status --json | grep DNSName
EXPO_PUBLIC_API_BASE_URL=http://ryx-mac-mini.tail73ed8.ts.net:4000

# Comma-separated fallbacks probed when the preferred host is unreachable —
# the Mini's LAN IP covers "home WiFi, Tailscale off". Find it on the Mini
# with: ipconfig getifaddr en1   (en1 = WiFi; en0 = Ethernet)
EXPO_PUBLIC_API_FALLBACK_URLS=http://192.168.3.169:4000

# Expo inlines EXPO_PUBLIC_* at bundle time — restart `expo start` (and
# rebuild the APK) after changing either. On web the app also tries the page's
# own hostname on :4000 first, since the backend serves the web build itself.

# Mock mode (explicit opt-in). true = UI runs on bundled fake data, no backend
# needed. Anything else = real backend only; connection failures are surfaced.
EXPO_PUBLIC_USE_MOCK=false
