# ══════════════════════════════════════════════════
#  NeuroPal Backend — Environment (local-first MVP)
# ══════════════════════════════════════════════════
# Copy to .env and fill in:  cp .env.example .env
# Brief §8. All services run locally on the backend host (Mac Mini M4).

# ── Server ───────────────────────────────────────
PORT=4000

# ── MongoDB (Docker, localhost) ──────────────────
# MONGO_ROOT_USER / MONGO_ROOT_PASSWORD seed the Docker container
# (docker-compose.yml reads them). Keep them in sync with the user:pass
# embedded in MONGODB_URI. URL-escape specials in the URI (! → %21).
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=CHANGE_ME
MONGODB_URI=mongodb://admin:CHANGE_ME@localhost:27017/neuropal?authSource=admin

# ── Qdrant (Docker, localhost) ───────────────────
QDRANT_URL=http://localhost:6333
# Local Qdrant runs without auth (localhost-bound). Leave empty.
QDRANT_API_KEY=

# ── Embeddings — always local via Ollama ─────────
EMBEDDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# ── Reasoning provider (Brief §6) ────────────────
# gemini (default, free) | ollama (offline/private) | anthropic (paid)
AI_PROVIDER=gemini

# Gemini — free key from https://aistudio.google.com
GEMINI_API_KEY=
# Exact model id is verified against live Google docs before coding (Phase 1).
GEMINI_MODEL=gemini-2.5-flash

# Ollama local reasoning fallback (used when AI_PROVIDER=ollama)
OLLAMA_CHAT_MODEL=qwen2.5:7b

# Anthropic — optional "best quality" toggle (AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Auth ─────────────────────────────────────────
# LOCAL_MODE=true → single fixed user, token verification skipped (Brief §2.7).
LOCAL_MODE=true
# Required for the LOCAL_MODE=false path. 32+ chars.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME

# ── File storage ─────────────────────────────────
STORAGE_ROOT=./storage

# Watched drop-folder for auto-ingest (LOCAL_MODE only). Finder-friendly path
# recommended, e.g. ~/NeuroPal-Inbox. Default: <STORAGE_ROOT>/inbox
INBOX_DIR=

# Optional: static web app dir (npx expo export -p web) served at /
WEB_DIST=
# Optional: release APK served at /apk with the correct Android MIME type
APK_PATH=

# P1 equations — local math-extraction microservice (neuropal-mathserve).
# Leave unset/down to skip the nougat tier (ingest falls back to pdf-parse).
MATHSERVE_URL=http://localhost:8077
# Math-glyph density (per 1000 chars of pdf-parse text) above which a PDF
# is routed through nougat.
MATH_DENSITY_MIN=1.5
# Shared secret with neuropal-mathserve (same value in its .env) — the
# service reads PDFs off disk and must not be an open localhost oracle.
MATHSERVE_TOKEN=
